{
  "entities": {
    "GoldPrice": {
      "title": "Gold Price",
      "description": "Bảng giá vàng hiện tại cho cửa hàng.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "Loại vàng (Vàng 9999, SJC, 24K, 18K...)" },
        "buyPrice": { "type": "number", "description": "Giá mua vào" },
        "sellPrice": { "type": "number", "description": "Giá bán ra" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "buyPrice", "sellPrice", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Lịch sử mua bán vàng.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["buy", "sell"], "description": "Loại giao dịch (Mua vào/Bán ra)" },
        "goldType": { "type": "string", "description": "Loại vàng giao dịch" },
        "weight": { "type": "number", "description": "Trọng lượng (Chỉ/Lượng/Gram)" },
        "unit": { "type": "string", "enum": ["chi", "luong", "gram"], "description": "Đơn vị tính" },
        "totalPrice": { "type": "number", "description": "Tổng giá trị giao dịch" },
        "customerID": { "type": "string", "description": "Số CCCD của khách hàng" },
        "customerName": { "type": "string", "description": "Tên khách hàng" },
        "customerAddress": { "type": "string", "description": "Địa chỉ khách hàng" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["cash", "transfer"] }
      },
      "required": ["type", "goldType", "weight", "totalPrice", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Thông tin khách hàng từ CCCD.",
      "type": "object",
      "properties": {
        "cccdId": { "type": "string", "description": "Số CCCD" },
        "fullName": { "type": "string", "description": "Họ và tên" },
        "address": { "type": "string", "description": "Địa chỉ thường trú" },
        "dob": { "type": "string", "description": "Ngày sinh" },
        "lastTransaction": { "type": "string", "format": "date-time" }
      },
      "required": ["cccdId", "fullName"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Tồn kho vàng của cửa hàng.",
      "type": "object",
      "properties": {
        "goldType": { "type": "string", "description": "Loại vàng" },
        "totalWeight": { "type": "number", "description": "Trọng lượng tồn kho" },
        "unit": { "type": "string" }
      },
      "required": ["goldType", "totalWeight"]
    }
  },
  "firestore": {
    "/gold_prices/{priceId}": { "schema": "GoldPrice", "description": "Bảng giá vàng niêm yết" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Danh sách giao dịch mua bán" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Dữ liệu khách hàng" },
    "/inventory/{inventoryId}": { "schema": "Inventory", "description": "Quản lý kho" }
  }
}
