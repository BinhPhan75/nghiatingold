rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: gold_prices
    // Fields: type (string), buyPrice (number), sellPrice (number), updatedAt (timestamp)
    //
    // Collection: transactions
    // Fields: type (string: buy/sell), goldType (string), weight (number), totalPrice (number), 
    //         customerID (string), customerName (string), createdAt (timestamp), 
    //         status (string), paymentMethod (string), uid (string)
    //
    // Collection: customers
    // Fields: cccdId (string), fullName (string), address (string), lastTransaction (timestamp)
    //
    // Collection: inventory
    // Fields: goldType (string), totalWeight (number)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "binhphan.070582@gmail.com");
    }

    function isValidGoldPrice(data) {
      return data.type is string && data.buyPrice is number && data.sellPrice is number;
    }

    function isValidTransaction(data) {
      return data.type in ['buy', 'sell'] && 
             data.goldType is string && 
             data.weight is number && 
             data.totalPrice is number &&
             data.weight > 0 &&
             data.totalPrice >= 0;
    }

    function isValidCustomer(data) {
      return data.cccdId is string && data.fullName is string;
    }

    // Rules
    match /gold_prices/{priceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidCustomer(request.resource.data);
    }

    match /inventory/{inventoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
  }
}
